<html lang="en">

<head>
  <meta charset="utf-8">

  <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">

  <title>Page Not Found (404)  | Ably Realtime</title>

  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta http-equiv="cleartype" content="on">

  <link href="/static/error/styles.css" rel="stylesheet" type="text/css" />

  <script type="text/javascript">
    var stylesheets = document.getElementsByTagName("head")[0].getElementsByTagName("link"),
        primary = stylesheets[stylesheets.length - 1];
    if (/^https?:\/\/(localhost|127.0.0.1|0.0.0.0)/.test(location.href)) {
      primary.href = primary.href.replace('//ably.com/', './');
      console.debug('Loading local style sheet from ' + stylesheets[stylesheets.length - 1].href);
    }
  </script>

  <script src="https://unpkg.com/@webcomponents/webcomponentsjs@2.1.3/webcomponents-bundle.js"></script>
  <script src="https://unpkg.com/@statuspage/status-widget/dist/index.js"></script>
</head>

  <body class="page-error error-404 error-section">
    <div class="error-section">
      <div class="header-wrap">
        <header id="header" class="header fixed-div">
          <div class="container">
            <a href="//ably.com" id="header-logo" class="header-logo"><h1>ably</h1></a>
            <a href="//ably.com" class="home-link pull-right">Ably home<span class="error-home-icon"></span></a>
          </div>
          <div class="clearfix"></div>
        </header>
      </div>

      <div id="main" class="main-content" role="main">
        <div class="container">
          <div class="error-content">
            <h1>Error - page not found</h1>
            <h2>4<span>oh!</span>4</h2>
            <p class="error-note">
              We feel your surprise, we didn&rsquo;t expect this either.<br> Many robots will now be deployed to <del>take over the world</del> search for this missing page.
              <br><br>
              If you need help, you should visit <a href="https://ably.com/support">our support desk</a>. If you believe there is an issue with our service, visit our <a href="https://status.ably.com">service status website</a>
            </p>
            <div class="graphic-error-404">
              <div class="img"></div>
            </div>
          </div>
          <div class="status">
            <h1>Ably global service status</h1>
            <statuspage-widget src="https://status.ably.com"></statuspage-widget>
          </div>
        </div>
      </div>
    </div>

  </body>

  <script>
    (function(i,s,o,g,r,a,m){i['GoogleAnalyticsObject']=r;i[r]=i[r]||function(){
    (i[r].q=i[r].q||[]).push(arguments)},i[r].l=1*new Date();a=s.createElement(o),
    m=s.getElementsByTagName(o)[0];a.async=1;a.src=g;m.parentNode.insertBefore(a,m)
    })(window,document,'script','//www.google-analytics.com/analytics.js','ga');

    ga('create', 'UA-36212453-1', 'auto');
    ga('send', 'pageview');
  </script>

  <script src="/live-chat.js" type="text/javascript"></script>
</html>

